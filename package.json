{
  "name": "z-skill",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.15.0"
  },
  "scripts": {
    "dev": "vinext dev",
    "build": "npm run validate:release && vinext build",
    "start": "wrangler dev --config dist/server/wrangler.json",
    "validate:release": "node --experimental-strip-types scripts/validate-release.mjs",
    "build:web-reader": "node scripts/build-web-content-reader-releases.mjs",
    "test:web-reader": "node --test tests/web-content-reader-release.test.mjs",
    "test:web-reader:smoke": "pwsh -NoProfile -File tests/web-content-reader-smoke.ps1",
    "test": "npm run test:web-reader && npm run build && node --experimental-strip-types --test tests/rendered-html.test.mjs",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "audit": "npm audit --audit-level=high"
  },
  "dependencies": {
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.44.0",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.1.4",
    "wrangler": "4.110.0"
  },
  "type": "module"
}
